.state-card {
  margin-top: 24rpx;
  padding: 56rpx 32rpx;
  text-align: center;
}

.state-tag {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f5eee6;
  color: #8d6e5a;
  font-size: 22rpx;
}

.state-title {
  margin-top: 24rpx;
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2d241d;
}

.state-copy {
  margin-top: 18rpx;
  display: block;
  color: #7d7368;
  line-height: 1.7;
}

.state-actions {
  margin-top: 32rpx;
  display: flex;
  gap: 18rpx;
}

.state-button {
  flex: 1;
}

.address-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.address-card {
  padding: 28rpx;
}

.address-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.address-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d241d;
}

.address-phone {
  color: #746b61;
  font-size: 24rpx;
}

.address-selected {
  color: #c96b48;
  font-size: 24rpx;
}

.address-detail {
  display: block;
  margin-top: 18rpx;
  color: #6f665c;
  line-height: 1.7;
}

.address-actions {
  margin-top: 22rpx;
  display: flex;
  gap: 24rpx;
}

.address-action {
  color: #6f665c;
  font-size: 24rpx;
}

.address-action-disabled {
  opacity: 0.45;
}

.danger {
  color: #c05b4a;
}

.empty-box {
  margin-top: 24rpx;
  padding: 56rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #2d241d;
}

.empty-copy {
  margin-top: 16rpx;
  display: block;
  color: #7f7569;
  line-height: 1.7;
}

.add-button {
  margin-top: 28rpx;
}
