.state-card {
  margin-top: 24rpx;
  padding: 56rpx 32rpx;
  text-align: center;
}

.state-tag {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f5eee6;
  color: #8d6e5a;
  font-size: 22rpx;
}

.state-title {
  margin-top: 24rpx;
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2d241d;
}

.state-copy {
  margin-top: 18rpx;
  display: block;
  color: #7d7368;
  line-height: 1.7;
}

.state-actions {
  margin-top: 32rpx;
  display: flex;
  gap: 18rpx;
}

.state-button {
  flex: 1;
}

.aftersale-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.block-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #281f19;
}

.aftersale-order {
  display: block;
  margin-top: 18rpx;
  color: #2d241d;
  font-size: 30rpx;
  font-weight: 700;
}

.aftersale-copy {
  display: block;
  margin-top: 14rpx;
  color: #776d63;
  line-height: 1.7;
}

.aftersale-status,
.aftersale-time {
  display: block;
  margin-top: 16rpx;
}

.aftersale-status {
  color: #b4512d;
  font-size: 24rpx;
}

.aftersale-time {
  color: #857b70;
  font-size: 24rpx;
}

.reason-list {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.reason-chip {
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: #f5f0e6;
  color: #6c6359;
}

.reason-chip-active {
  background: #fff2eb;
  color: #c96b48;
  font-weight: 700;
}

.order-item-row,
.amount-row {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.order-item-main {
  flex: 1;
}

.order-item-title {
  display: block;
  color: #2d241d;
  font-size: 28rpx;
}

.order-item-meta {
  display: block;
  margin-top: 8rpx;
  color: #7e7468;
  font-size: 24rpx;
}

.order-item-price {
  color: #b4512d;
  font-size: 28rpx;
  font-weight: 700;
}

.amount-label,
.amount-value {
  color: #6f665b;
  font-size: 24rpx;
}

.amount-label-strong,
.amount-value-strong {
  color: #b4512d;
  font-size: 28rpx;
  font-weight: 700;
}

.aftersale-order-info {
  display: block;
  margin-top: 18rpx;
  color: #2d241d;
  font-size: 28rpx;
  font-weight: 700;
}

.process-row {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.process-dot {
  width: 16rpx;
  height: 16rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #ded5ca;
  flex-shrink: 0;
}

.process-dot-active {
  background: #c96b48;
}

.process-main {
  flex: 1;
}

.process-title {
  display: block;
  color: #84796d;
  font-size: 28rpx;
  font-weight: 700;
}

.process-title-active {
  color: #2d241d;
}

.process-copy {
  display: block;
  margin-top: 8rpx;
  color: #7e7468;
  font-size: 24rpx;
  line-height: 1.6;
}

.tip-row {
  margin-top: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0ebe1;
}

.tip-row:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.tip-title {
  display: block;
  color: #2d241d;
  font-size: 28rpx;
  font-weight: 700;
}

.tip-copy {
  display: block;
  margin-top: 10rpx;
  color: #776d63;
  font-size: 24rpx;
  line-height: 1.6;
}

.aftersale-textarea {
  margin-top: 18rpx;
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: #f7f4ed;
  border-radius: 20rpx;
}

.aftersale-button {
  margin-top: 28rpx;
}
