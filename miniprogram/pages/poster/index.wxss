.state-card {
  margin-top: 24rpx;
  padding: 56rpx 32rpx;
  text-align: center;
}

.state-tag {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f5eee6;
  color: #8d6e5a;
  font-size: 22rpx;
}

.state-title {
  display: block;
  margin-top: 20rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #2d241d;
}

.state-copy {
  display: block;
  margin-top: 18rpx;
  color: #756b60;
  line-height: 1.7;
}

.state-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 18rpx;
}

.state-button {
  flex: 1;
}

.poster-card {
  padding: 40rpx 32rpx;
  border-radius: 36rpx;
  background: linear-gradient(160deg, #f0dccd, #fff8f3);
}

.poster-kicker {
  color: #9f5e42;
  font-size: 24rpx;
  font-weight: 700;
}

.poster-title {
  display: block;
  margin-top: 18rpx;
  font-size: 46rpx;
  font-weight: 700;
  color: #2d241d;
}

.poster-copy {
  display: block;
  margin-top: 18rpx;
  color: #73695e;
  line-height: 1.7;
}

.poster-coupon {
  margin-top: 28rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.78);
}

.poster-coupon-empty {
  text-align: center;
}

.poster-coupon-amount {
  display: block;
  color: #b4512d;
  font-size: 56rpx;
  font-weight: 700;
}

.poster-coupon-copy {
  display: block;
  margin-top: 10rpx;
  color: #7a7065;
  font-size: 24rpx;
}

.poster-code {
  width: 280rpx;
  height: 280rpx;
  margin: 36rpx auto 0;
  border-radius: 24rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-code-text {
  color: #8a8074;
  font-size: 28rpx;
}

.poster-button {
  margin-top: 24rpx;
}
