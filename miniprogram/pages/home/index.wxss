.state-card {
  margin-top: 24rpx;
  padding: 56rpx 32rpx;
  text-align: center;
}

.state-tag {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f5eee6;
  color: #8d6e5a;
  font-size: 22rpx;
}

.state-title {
  margin-top: 24rpx;
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2d241d;
}

.state-copy {
  margin-top: 18rpx;
  display: block;
  color: #7d7368;
  line-height: 1.7;
}

.state-actions {
  margin-top: 32rpx;
  display: flex;
  gap: 18rpx;
}

.state-button {
  flex: 1;
}

.content-empty {
  margin-top: 20rpx;
  padding: 40rpx 32rpx;
  text-align: center;
}

.content-empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #2d241d;
}

.content-empty-copy {
  margin-top: 16rpx;
  display: block;
  color: #7e7468;
  line-height: 1.7;
}

.home-shell {
  padding-bottom: 36rpx;
}

.hero {
  padding: 34rpx;
  background: linear-gradient(145deg, #1f473d, #4d7c68 55%, #d9e7de);
}

.hero-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-kicker {
  color: rgba(255, 245, 226, 0.86);
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 14rpx;
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff9ef;
  line-height: 1.2;
}

.hero-status {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 250, 238, 0.82);
  font-size: 22rpx;
  font-weight: 700;
}

.hero-status-active {
  background: rgba(255, 240, 206, 0.22);
  color: #fff4d9;
}

.hero-copy {
  margin-top: 22rpx;
  display: block;
  color: rgba(255, 249, 239, 0.82);
  line-height: 1.7;
}

.hero-search {
  margin-top: 26rpx;
  padding: 22rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.hero-search-text {
  color: rgba(255, 250, 240, 0.78);
  font-size: 24rpx;
}

.hero-badges {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 249, 237, 0.82);
  font-size: 22rpx;
}

.hero-stats {
  margin-top: 26rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.hero-stat {
  width: 48%;
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.12);
}

.hero-stat-value {
  display: block;
  color: #fff8ed;
  font-size: 36rpx;
  font-weight: 700;
}

.hero-stat-label {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 248, 237, 0.74);
  font-size: 22rpx;
}

.banner-strip {
  margin-top: 24rpx;
}

.banner-card {
  margin-bottom: 18rpx;
  padding: 28rpx;
}

.banner-title {
  display: block;
  color: #2d241d;
  font-size: 32rpx;
  font-weight: 700;
}

.banner-subtitle {
  margin-top: 12rpx;
  display: block;
  color: #675d52;
  font-size: 24rpx;
  line-height: 1.6;
}

.banner-footer {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.banner-meta {
  color: #60574d;
  font-size: 22rpx;
}

.banner-link {
  color: #255847;
  font-size: 24rpx;
  font-weight: 700;
}

.benefit-grid {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.benefit-card {
  width: 48%;
  min-height: 248rpx;
  margin-bottom: 18rpx;
  padding: 26rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.benefit-card-coupon {
  background: linear-gradient(155deg, #fff8f0, #ffe6ce);
}

.benefit-card-distribution {
  background: linear-gradient(155deg, #edf8f2, #d7efe3);
}

.benefit-badge {
  display: inline-flex;
  align-self: flex-start;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #6d5a46;
  font-size: 22rpx;
  font-weight: 700;
}

.benefit-title {
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #2b251f;
}

.benefit-subtitle {
  margin-top: 14rpx;
  color: #665d53;
  font-size: 24rpx;
  line-height: 1.6;
}

.benefit-footer {
  margin-top: auto;
  padding-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.benefit-meta {
  color: #60574d;
  font-size: 22rpx;
}

.benefit-link {
  color: #255847;
  font-size: 24rpx;
  font-weight: 700;
}

.promo-banner {
  margin-top: 6rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #20231f, #40483e);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
}

.promo-main {
  flex: 1;
}

.promo-kicker {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 233, 191, 0.14);
  color: #f2deb3;
  font-size: 22rpx;
  font-weight: 700;
}

.promo-title {
  margin-top: 16rpx;
  display: block;
  color: #fff8ed;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.promo-copy {
  margin-top: 12rpx;
  display: block;
  color: rgba(255, 247, 235, 0.72);
  font-size: 24rpx;
  line-height: 1.6;
}

.promo-link {
  flex-shrink: 0;
  color: #ffe2a5;
  font-size: 26rpx;
  font-weight: 700;
}

.section-head {
  margin-top: 34rpx;
}

.entry-grid {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.entry-card {
  width: 48%;
  min-height: 156rpx;
  margin-bottom: 18rpx;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c251f;
}

.entry-subtitle {
  color: #7d7368;
  font-size: 22rpx;
  line-height: 1.5;
}

.product-list {
  margin-top: 20rpx;
}

.product-card {
  padding: 24rpx;
  display: flex;
  margin-bottom: 20rpx;
}

.product-cover {
  width: 188rpx;
  height: 188rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-cover-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #4a3c33;
}

.product-content {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.product-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-sales {
  color: #8a8074;
  font-size: 22rpx;
}

.product-title {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #2d241d;
}

.product-desc {
  margin-top: 12rpx;
  color: #7e7468;
  font-size: 24rpx;
  line-height: 1.6;
}

.product-benefits {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.product-benefit-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f4efe5;
  color: #6f665b;
  font-size: 22rpx;
  font-weight: 700;
}

.product-benefit-chip-strong {
  background: #edf6f1;
  color: #2b6b53;
}

.product-commission {
  color: #2b6b53;
  font-size: 22rpx;
  font-weight: 700;
}

.product-highlights {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.product-highlight {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff5ef;
  color: #b06441;
  font-size: 22rpx;
}

.product-spec {
  margin-top: 14rpx;
  color: #867b70;
  font-size: 22rpx;
}

.recommend-list {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.recommend-card {
  width: 48%;
  margin-bottom: 18rpx;
  padding: 22rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.recommend-cover {
  height: 220rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recommend-cover-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #493d35;
}

.recommend-title {
  margin-top: 18rpx;
  color: #2c251f;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
  white-space: normal;
}

.recommend-top {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.recommend-sales {
  color: #8a8074;
  font-size: 22rpx;
}

.recommend-meta {
  margin-top: 10rpx;
  color: #82786d;
  font-size: 22rpx;
  line-height: 1.5;
}

.recommend-hint {
  margin-top: 10rpx;
  color: #2b6b53;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.5;
}

.recommend-price {
  margin-top: 12rpx;
  color: #b4512d;
  font-size: 32rpx;
  font-weight: 700;
}
