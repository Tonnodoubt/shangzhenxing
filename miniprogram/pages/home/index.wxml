<view class="page-shell home-shell">
  <view class="panel state-card" wx:if="{{pageState === 'loading'}}">
    <text class="state-tag">首页</text>
    <text class="state-title">首页内容加载中</text>
    <text class="state-copy">正在同步主视觉、品类入口、领券福利和首页商品。</text>
  </view>

  <view class="panel state-card" wx:elif="{{pageState === 'error'}}">
    <text class="state-tag">加载失败</text>
    <text class="state-title">首页暂时不可用</text>
    <text class="state-copy">{{errorMessage || '网络异常，请稍后重试。'}}</text>
    <view class="state-actions">
      <button class="ghost-button state-button" bindtap="openCategory">查看分类</button>
      <button class="primary-button state-button" bindtap="retryLoad">重新加载</button>
    </view>
  </view>

  <view wx:else>
    <swiper class="hero-swiper"
            indicator-dots="{{true}}"
            indicator-color="rgba(255,255,255,0.4)"
            indicator-active-color="rgba(255,255,255,0.88)"
            autoplay="{{true}}"
            interval="{{4000}}"
            circular="{{true}}"
            current="{{activeBannerIndex}}"
            bindchange="swiperChange">
      <block wx:for="{{banners}}" wx:key="id">
        <swiper-item>
          <view class="hero-slide" bindtap="onBannerTap" data-index="{{index}}" data-link-type="{{item.linkType}}" data-link-value="{{item.linkValue}}">
            <image wx:if="{{item.imageUrl}}" class="hero-slide-image" src="{{item.imageUrl}}" mode="aspectFill" />
            <view wx:else class="hero-slide-fallback">
              <text class="hero-slide-title">{{item.title}}</text>
              <text wx:if="{{item.subtitle}}" class="hero-slide-subtitle">{{item.subtitle}}</text>
            </view>
          </view>
        </swiper-item>
      </block>
    </swiper>

    <view class="panel category-rack">
      <block wx:for="{{categoryNav}}" wx:key="id">
        <view class="category-pill" data-id="{{item.id}}" bindtap="openCategory">
          <view class="category-seal" style="background: {{item.accent}};">
            <text class="category-seal-text">{{item.sealText}}</text>
          </view>
          <text class="category-name">{{item.name}}</text>
        </view>
      </block>
    </view>

    <view class="panel benefit-card" bindtap="openCoupons">
      <view class="benefit-notch benefit-notch-left"></view>
      <view class="benefit-notch benefit-notch-right"></view>
      <view class="benefit-header">
        <text class="benefit-badge">{{benefitCard.badge}}</text>
        <view class="benefit-secondary-link" catchtap="openDistribution">{{benefitCard.secondaryText}}</view>
      </view>
      <text class="benefit-title">{{benefitCard.title}}</text>
      <text class="benefit-copy">{{benefitCard.copy}}</text>
      <view class="benefit-footer">
        <text class="benefit-meta">{{benefitCard.footer}}</text>
        <view class="benefit-button">{{benefitCard.primaryText}}</view>
      </view>
    </view>

    <view class="feature-story panel" data-id="{{featureStory.id}}" bindtap="openProduct">
      <view class="feature-story-visual" style="background: {{featureStory.accent}};">
        <text class="feature-story-kicker">{{featureStory.kicker}}</text>
        <text class="feature-story-seal">{{featureStory.coverLabel}}</text>
      </view>
      <view class="feature-story-content">
        <text class="feature-story-title">{{featureStory.title}}</text>
        <text class="feature-story-copy">{{featureStory.copy}}</text>
      </view>
    </view>

    <view class="product-grid">
      <block wx:for="{{productGrid}}" wx:key="id">
        <view class="panel product-card" data-id="{{item.id}}" bindtap="openProduct">
          <view class="product-cover" style="background: {{item.accent}};">
            <text class="product-cover-badge">{{item.tag}}</text>
            <text class="product-cover-text">{{item.coverLabel}}</text>
          </view>
          <view class="product-info">
            <text class="product-title">{{item.title}}</text>
            <text class="product-sales">{{item.salesText}}</text>
            <view class="price-row product-price-row">
              <text class="price-now">¥{{item.displayPrice}}</text>
              <text class="price-origin">¥{{item.displayMarketPrice}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
