.state-card {
  margin-top: 24rpx;
  padding: 56rpx 32rpx;
  text-align: center;
}

.state-tag {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f5eee6;
  color: #8d6e5a;
  font-size: 22rpx;
}

.state-title {
  margin-top: 24rpx;
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2d241d;
}

.state-copy {
  margin-top: 18rpx;
  display: block;
  color: #7d7368;
  line-height: 1.7;
}

.state-actions {
  margin-top: 32rpx;
  display: flex;
  gap: 18rpx;
}

.state-button {
  flex: 1;
}

.content-empty {
  margin-top: 22rpx;
  padding: 48rpx 28rpx;
  text-align: center;
}

.content-empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #2d241d;
}

.content-empty-copy {
  margin-top: 16rpx;
  color: #796f64;
  line-height: 1.7;
}

.team-hero {
  padding: 28rpx;
}

.team-stats {
  margin-top: 22rpx;
  display: flex;
  justify-content: space-between;
}

.team-stat {
  width: 48%;
  padding: 24rpx;
  box-sizing: border-box;
}

.team-stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2d241d;
}

.team-stat-label {
  display: block;
  margin-top: 12rpx;
  color: #7b7268;
  font-size: 24rpx;
}

.team-list {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.team-card {
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.team-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: #f0dccd;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7a4d38;
  font-weight: 700;
  flex-shrink: 0;
}

.team-main {
  margin-left: 20rpx;
}

.team-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2d241d;
}

.team-meta {
  display: block;
  margin-top: 8rpx;
  color: #796f64;
  font-size: 24rpx;
}
