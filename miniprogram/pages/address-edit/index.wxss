.state-card {
  margin-top: 24rpx;
  padding: 56rpx 32rpx;
  text-align: center;
}

.state-tag {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f5eee6;
  color: #8d6e5a;
  font-size: 22rpx;
}

.state-title {
  margin-top: 24rpx;
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2d241d;
}

.state-copy {
  margin-top: 18rpx;
  display: block;
  color: #7d7368;
  line-height: 1.7;
}

.state-actions {
  margin-top: 32rpx;
  display: flex;
  gap: 18rpx;
}

.state-button {
  flex: 1;
}

.form-card {
  padding: 28rpx;
}

.form-item {
  margin-bottom: 26rpx;
}

.form-label {
  display: block;
  color: #2d241d;
  font-size: 28rpx;
  font-weight: 700;
}

.form-input,
.form-textarea {
  display: block;
  width: 100%;
  margin-top: 14rpx;
  box-sizing: border-box;
  background: #f7f4ed;
  border-radius: 20rpx;
  color: #2d241d;
  font-size: 28rpx;
}

.form-input {
  height: 84rpx;
  padding: 0 24rpx;
  line-height: 84rpx;
}

.form-textarea {
  min-height: 220rpx;
  padding: 24rpx;
  line-height: 1.6;
}

.form-placeholder {
  color: #a3998d;
  font-size: 28rpx;
}

.default-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.default-toggle {
  color: #c96b48;
  font-size: 24rpx;
}

.save-button {
  margin-top: 28rpx;
}
