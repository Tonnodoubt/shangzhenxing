<view class="page-shell">
  <view class="panel state-card" wx:if="{{pageState === 'loading'}}">
    <text class="state-tag">地址编辑</text>
    <text class="state-title">地址信息加载中</text>
    <text class="state-copy">正在同步这条地址的详细信息。</text>
  </view>

  <view class="panel state-card" wx:elif="{{pageState === 'error'}}">
    <text class="state-tag">加载失败</text>
    <text class="state-title">地址页暂时不可用</text>
    <text class="state-copy">{{errorMessage || '网络异常，请稍后重试。'}}</text>
    <view class="state-actions">
      <button class="ghost-button state-button" bindtap="backList">返回上一页</button>
      <button class="primary-button state-button" bindtap="retryLoad">重新加载</button>
    </view>
  </view>

  <view class="panel state-card" wx:elif="{{pageState === 'notFound'}}">
    <text class="state-tag">地址不存在</text>
    <text class="state-title">这条地址可能已经被删除</text>
    <text class="state-copy">{{errorMessage || '你可以返回地址列表重新选择，或者新增一条地址。'}}</text>
    <view class="state-actions">
      <button class="primary-button state-button" bindtap="backList">返回上一页</button>
    </view>
  </view>

  <view wx:else>
    <view class="panel form-card">
      <view class="form-item">
        <text class="form-label">收件人</text>
        <input
          class="form-input"
          placeholder-class="form-placeholder"
          value="{{form.receiver}}"
          data-field="receiver"
          bindinput="handleInput"
          placeholder="请输入收件人"
        />
      </view>
      <view class="form-item">
        <text class="form-label">手机号</text>
        <input
          class="form-input"
          placeholder-class="form-placeholder"
          value="{{form.phone}}"
          data-field="phone"
          bindinput="handleInput"
          placeholder="请输入 11 位手机号"
          type="number"
        />
      </view>
      <view class="form-item">
        <text class="form-label">详细地址</text>
        <textarea
          class="form-textarea"
          placeholder-class="form-placeholder"
          value="{{form.detail}}"
          data-field="detail"
          bindinput="handleInput"
          placeholder="请输入详细地址"
        />
      </view>
      <view class="form-item">
        <text class="form-label">地址标签</text>
        <input
          class="form-input"
          placeholder-class="form-placeholder"
          value="{{form.tag}}"
          data-field="tag"
          bindinput="handleInput"
          placeholder="例如：家 / 公司"
        />
      </view>
      <view class="default-row" bindtap="toggleDefault">
        <text class="form-label">设为默认地址</text>
        <text class="default-toggle">{{form.isDefault ? '已设为默认' : '点击开启'}}</text>
      </view>
    </view>

    <button class="primary-button save-button" bindtap="saveAddress" loading="{{saving}}" disabled="{{saving}}">
      {{saving ? '保存中...' : '保存地址'}}
    </button>
  </view>
</view>
