.state-card {
  margin-top: 24rpx;
  padding: 56rpx 32rpx;
  text-align: center;
}

.state-tag {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f5eee6;
  color: #8d6e5a;
  font-size: 22rpx;
}

.state-title {
  margin-top: 24rpx;
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2d241d;
}

.state-copy {
  margin-top: 18rpx;
  display: block;
  color: #7d7368;
  line-height: 1.7;
}

.state-actions {
  margin-top: 32rpx;
  display: flex;
  gap: 18rpx;
}

.state-button {
  flex: 1;
}

.profile-shell {
  padding-bottom: 64rpx;
}

.profile-hero {
  padding: 40rpx 34rpx 34rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #f3e7d8 0%, #f7efe4 46%, #dbece3 100%);
}

.profile-hero-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.profile-hero-main {
  flex: 1;
  min-width: 0;
}

.profile-kicker {
  display: block;
  color: #8a6a56;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.profile-name {
  display: block;
  margin-top: 18rpx;
  font-size: 50rpx;
  font-weight: 700;
  color: #2d241d;
  line-height: 1.16;
}

.profile-phone {
  display: block;
  margin-top: 14rpx;
  color: #6f655a;
  font-size: 24rpx;
}

.profile-copy {
  display: block;
  width: 70%;
  margin-top: 20rpx;
  color: #74695d;
  font-size: 24rpx;
  line-height: 1.7;
}

.profile-auth-chip {
  flex-shrink: 0;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #2b6b53;
  font-size: 22rpx;
  font-weight: 700;
}

.profile-note {
  margin-top: 34rpx;
  padding: 24rpx 24rpx 26rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.62);
}

.profile-note-label {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #8a6a56;
  font-size: 20rpx;
  font-weight: 700;
}

.profile-note-copy {
  display: block;
  margin-top: 16rpx;
  color: #6f655a;
  font-size: 24rpx;
  line-height: 1.7;
}

.service-section {
  margin-top: 24rpx;
  padding: 30rpx 30rpx 10rpx;
}

.profile-section-head {
  margin-bottom: 12rpx;
}

.service-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0ebe1;
}

.service-row:last-child {
  border-bottom: 0;
}

.service-row-main {
  flex: 1;
  min-width: 0;
}

.service-row-title {
  display: block;
  color: #2d241d;
  font-size: 28rpx;
  font-weight: 700;
}

.service-row-copy {
  display: block;
  margin-top: 10rpx;
  color: #83796d;
  font-size: 22rpx;
  line-height: 1.55;
}

.service-row-side {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.service-row-value {
  color: #2b6b53;
  font-size: 24rpx;
  font-weight: 700;
}

.service-row-arrow {
  color: #b7aea3;
  font-size: 32rpx;
  line-height: 1;
}
