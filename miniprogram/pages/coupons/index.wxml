<view class="page-shell coupon-page">
  <view class="panel state-card" wx:if="{{pageState === 'loading'}}">
    <text class="state-tag">优惠券</text>
    <text class="state-title">优惠券数据加载中</text>
    <text class="state-copy">正在同步可领取优惠券、已领取列表和当前选择状态。</text>
  </view>

  <view class="panel state-card" wx:elif="{{pageState === 'error'}}">
    <text class="state-tag">加载失败</text>
    <text class="state-title">优惠券页暂时不可用</text>
    <text class="state-copy">{{errorMessage || '网络异常，请稍后重试。'}}</text>
    <view class="state-actions">
      <button class="ghost-button state-button" bindtap="backProfile">返回我的</button>
      <button class="primary-button state-button" bindtap="retryLoad">重新加载</button>
    </view>
  </view>

  <view wx:else>
    <view class="coupon-page-head">
      <text class="coupon-page-title">领取优惠券</text>
      <text class="coupon-page-copy">新人券、满减券和活动券统一管理，领券后下单可自动抵扣。</text>
    </view>

    <view class="panel coupon-select-summary" wx:if="{{mode === 'select'}}">
      <text class="coupon-select-title">本次结算可选优惠券</text>
      <text class="coupon-select-copy">当前商品金额 ¥{{displayAmount}}，满足门槛的券可以直接选择。</text>
      <text class="coupon-select-link" bindtap="clearCoupon">{{actionLoadingId === 'clear' ? '处理中...' : '本次不使用优惠券'}}</text>
    </view>

    <view class="coupon-section-head">
      <text class="section-title">可领取优惠券</text>
      <text class="section-subtitle">领取后可在结算页直接使用。</text>
    </view>

    <view class="coupon-ticket-list" wx:if="{{centerTemplates.length}}">
      <block wx:for="{{centerTemplates}}" wx:key="id">
        <view class="coupon-ticket coupon-ticket-claim">
          <view class="coupon-ticket-notch coupon-ticket-notch-left"></view>
          <view class="coupon-ticket-notch coupon-ticket-notch-right"></view>
          <view class="coupon-ticket-value">
            <text class="coupon-currency">¥</text>
            <text class="coupon-value">{{item.amountText}}</text>
          </view>
          <view class="coupon-ticket-divider"></view>
          <view class="coupon-ticket-body">
            <view class="coupon-ticket-top">
              <view class="coupon-ticket-main">
                <text class="coupon-ticket-title">{{item.title}}</text>
                <text class="coupon-ticket-rule">{{item.ruleText}}</text>
              </view>
              <text class="coupon-ticket-badge">{{item.badge}}</text>
            </view>
            <view class="coupon-ticket-bottom">
              <text class="coupon-ticket-expiry">{{item.expiryText}}</text>
              <button
                class="coupon-ticket-button"
                bindtap="claimCoupon"
                data-id="{{item.id}}"
                loading="{{item.isLoading}}"
                disabled="{{item.claimed || actionLoadingId ? true : false}}"
              >
                {{item.actionText}}
              </button>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view class="panel content-empty" wx:else>
      <text class="content-empty-title">当前没有可领取的券</text>
      <text class="content-empty-copy">当前暂无可领取优惠券，可稍后再来看看。</text>
    </view>

    <view class="coupon-section-head">
      <text class="section-title">我的优惠券</text>
      <text class="section-subtitle">当前可用 {{availableCouponCount}} 张，已领取优惠券都会展示在这里。</text>
    </view>

    <view class="coupon-ticket-list" wx:if="{{coupons.length}}">
      <block wx:for="{{coupons}}" wx:key="id">
        <view
          class="coupon-ticket coupon-ticket-owned {{selectedCouponId === item.id ? 'coupon-ticket-active' : ''}} {{item.status !== 'available' ? 'coupon-ticket-disabled' : ''}}"
          data-id="{{item.id}}"
          data-selectable="{{mode !== 'select' ? false : item.isSelectable}}"
          data-reason="{{item.selectHint}}"
          bindtap="selectCoupon"
        >
          <view class="coupon-ticket-notch coupon-ticket-notch-left"></view>
          <view class="coupon-ticket-notch coupon-ticket-notch-right"></view>
          <view class="coupon-ticket-value">
            <text class="coupon-currency">¥</text>
            <text class="coupon-value">{{item.amountText}}</text>
          </view>
          <view class="coupon-ticket-divider"></view>
          <view class="coupon-ticket-body">
            <view class="coupon-ticket-top">
              <view class="coupon-ticket-main">
                <text class="coupon-ticket-title">{{item.title}}</text>
                <text class="coupon-ticket-rule">{{item.thresholdText}} · {{item.sourceText}}</text>
              </view>
              <text class="coupon-ticket-status {{item.statusToneClass}}">{{item.statusLabel}}</text>
            </view>
            <view class="coupon-ticket-bottom">
              <text class="coupon-ticket-expiry">{{item.expiryText}}</text>
              <text class="coupon-ticket-action" wx:if="{{mode === 'select'}}">
                {{item.isSelecting ? '选择中' : item.selectHint}}
              </text>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view class="panel empty-box" wx:else>
      <text class="empty-title">你还没有优惠券</text>
      <text class="empty-copy">先到上方领券区领取优惠券，领取成功后会显示在这里。</text>
    </view>
  </view>
</view>
