<view class="settings-shell">
  <view class="page-block" wx:if="{{pageState === 'loading'}}">
    <view class="state-card">
      <text class="state-title">设置加载中</text>
      <text class="state-copy">正在同步账号与设置项。</text>
    </view>
  </view>

  <view class="page-block" wx:elif="{{pageState === 'error'}}">
    <view class="state-card">
      <text class="state-title">设置页暂时不可用</text>
      <text class="state-copy">{{errorMessage || '请稍后再试。'}}</text>
      <button class="retry-btn" bindtap="retryLoad">重新加载</button>
    </view>
  </view>

  <view class="page-block" wx:else>
    <view class="user-card">
      <view class="user-avatar">
        <image
          wx:if="{{displayAvatarUrl}}"
          class="user-avatar-image"
          src="{{displayAvatarUrl}}"
          mode="aspectFill"
        ></image>
        <text wx:else class="user-avatar-label">{{displayAvatarLabel}}</text>
      </view>
      <view class="user-meta">
        <text class="user-name">{{user.nickname || '微信用户'}}</text>
        <text class="user-id">ID {{userIdLabel}}</text>
        <text class="user-phone">{{phoneMasked}}</text>
      </view>
    </view>

    <view class="menu-card">
      <button
        class="menu-row menu-row-button"
        open-type="chooseAvatar"
        bindchooseavatar="handleChooseAvatar"
        loading="{{profileSaving}}"
        disabled="{{profileSaving}}"
      >
        <text class="menu-label">头像</text>
        <view class="menu-row-side">
          <view class="menu-avatar-preview">
            <image
              wx:if="{{displayAvatarUrl}}"
              class="menu-avatar-preview-image"
              src="{{displayAvatarUrl}}"
              mode="aspectFill"
            ></image>
            <text wx:else class="menu-avatar-preview-label">{{displayAvatarLabel}}</text>
          </view>
          <text class="menu-value">修改</text>
          <text class="menu-arrow">›</text>
        </view>
      </button>

      <view class="menu-row" bindtap="handleEditNicknameTap">
        <text class="menu-label">昵称</text>
        <view class="menu-row-side">
          <text class="menu-value">{{nicknameDisplay}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="menu-card">
      <view class="menu-row" bindtap="openAddressList">
        <text class="menu-label">收货地址管理</text>
        <text class="menu-value">去查看</text>
      </view>
      <view class="menu-row" bindtap="openPrivacyPolicy">
        <text class="menu-label">隐私政策</text>
        <text class="menu-value">查看</text>
      </view>
      <view class="menu-row" bindtap="openServiceTerms">
        <text class="menu-label">服务条款</text>
        <text class="menu-value">查看</text>
      </view>
    </view>

    <button
      class="logout-btn"
      bindtap="handleLogout"
      loading="{{logoutSubmitting}}"
      disabled="{{logoutSubmitting}}"
    >
      {{logoutSubmitting ? '退出中...' : '退出登录'}}
    </button>
  </view>
</view>
