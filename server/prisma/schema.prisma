generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserStatus {
  active
  disabled
}

enum SessionStatus {
  active
  expired
  revoked
}

enum ProductStatus {
  on_sale
  off_sale
}

enum OrderStatus {
  pending
  shipping
  done
  cancelled
}

enum CouponTemplateStatus {
  enabled
  disabled
}

enum CouponIssueType {
  center_claim
  manual_issue
}

enum UserCouponStatus {
  available
  used
  expired
}

enum UserCouponSourceType {
  center_claim
  manual_issue
  system_grant
}

enum AfterSaleStatus {
  processing
  approved
  rejected
  done
}

enum DistributorStatus {
  active
  inactive
}

enum CommissionStatus {
  pending
  settled
  withdrawing
  withdrawn
  reversed
}

enum WithdrawalStatus {
  submitted
  approved
  rejected
  paying
  paid
  pay_failed
  cancelled
}

enum DistributionRuleVersionStatus {
  draft
  published
  archived
}

model User {
  id                    String              @id @default(cuid())
  openId                String?             @unique
  unionId               String?             @unique
  nickname              String
  avatarUrl             String?
  mobile                String?
  isAuthorized          Boolean             @default(false)
  status                UserStatus          @default(active)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  sessions              UserSession[]
  addresses             Address[]
  cart                  Cart?
  orders                Order[]
  coupons               UserCoupon[]
  afterSales            AfterSale[]
  distributorProfile    DistributorProfile?
  sentReferrals         ReferralBinding[]   @relation("UserSentReferrals")
  receivedReferral      ReferralBinding?    @relation("UserReceivedReferral")
  invitedOrders         Order[]             @relation("OrderInviter")
  invitedOrdersLevelTwo Order[]             @relation("OrderLevelTwoInviter")
}

model UserSession {
  id           String        @id @default(cuid())
  userId       String
  sessionToken String        @unique
  expiresAt    DateTime
  status       SessionStatus @default(active)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  receiver  String
  phone     String
  province  String?
  city      String?
  district  String?
  detail    String
  tag       String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([userId, isDefault])
}

model Category {
  id        String     @id @default(cuid())
  parentId  String?
  name      String
  sortOrder Int        @default(0)
  status    String     @default("enabled")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryChildren")
  products  Product[]

  @@index([parentId, sortOrder])
}

model Product {
  id                  String        @id @default(cuid())
  categoryId          String?
  title               String
  shortDesc           String?
  subTitle            String?
  coverImage          String?
  detailContent       String?       @db.LongText
  price               Decimal       @db.Decimal(10, 2)
  marketPrice         Decimal       @db.Decimal(10, 2)
  salesCount          Int           @default(0)
  favoriteCount       Int           @default(0)
  distributionEnabled Boolean       @default(true)
  status              ProductStatus @default(on_sale)
  sortOrder           Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  category            Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  skus                ProductSku[]
  cartItems           CartItem[]
  orderItems          OrderItem[]

  @@index([categoryId, status, sortOrder])
}

model ProductSku {
  id          String      @id @default(cuid())
  productId   String
  skuCode     String      @unique
  specText    String
  price       Decimal     @db.Decimal(10, 2)
  originPrice Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  lockStock   Int         @default(0)
  status      String      @default("enabled")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([productId, status])
}

model Cart {
  id               String      @id @default(cuid())
  userId           String      @unique
  selectedCouponId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            CartItem[]
  selectedCoupon   UserCoupon? @relation("SelectedCartCoupon", fields: [selectedCouponId], references: [id], onDelete: SetNull)
}

model CartItem {
  id        String      @id @default(cuid())
  cartId    String
  productId String
  skuId     String?
  title     String
  specText  String?
  price     Decimal     @db.Decimal(10, 2)
  quantity  Int         @default(1)
  selected  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  cart      Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  sku       ProductSku? @relation(fields: [skuId], references: [id], onDelete: SetNull)

  @@index([cartId, selected])
  @@index([productId])
}

model Order {
  id                       String                   @id @default(cuid())
  orderNo                  String                   @unique
  userId                   String
  addressId                String?
  referralBindingId        String?
  inviterUserId            String?
  levelTwoInviterUserId    String?
  status                   OrderStatus              @default(pending)
  sourceScene              String?
  ruleVersionId            String?
  goodsAmount              Decimal                  @db.Decimal(10, 2)
  discountAmount           Decimal                  @default(0.00) @db.Decimal(10, 2)
  payableAmount            Decimal                  @db.Decimal(10, 2)
  commissionBaseAmount     Decimal                  @default(0.00) @db.Decimal(10, 2)
  commissionRate           Decimal                  @default(0.0000) @db.Decimal(5, 4)
  commissionAmount         Decimal                  @default(0.00) @db.Decimal(10, 2)
  levelTwoCommissionRate   Decimal                  @default(0.0000) @db.Decimal(5, 4)
  levelTwoCommissionAmount Decimal                  @default(0.00) @db.Decimal(10, 2)
  couponTitle              String?
  remark                   String?
  // 地址快照
  snapReceiver             String?
  snapPhone                String?
  snapAddress              String?
  shipmentCompanyCode      String?
  shipmentCompanyName      String?
  shipmentTrackingNo       String?
  shippedAt                DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  user                     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address                  Address?                 @relation(fields: [addressId], references: [id], onDelete: SetNull)
  inviter                  User?                    @relation("OrderInviter", fields: [inviterUserId], references: [id], onDelete: SetNull)
  levelTwoInviter          User?                    @relation("OrderLevelTwoInviter", fields: [levelTwoInviterUserId], references: [id], onDelete: SetNull)
  referralBinding          ReferralBinding?         @relation(fields: [referralBindingId], references: [id], onDelete: SetNull)
  ruleVersion              DistributionRuleVersion? @relation("OrderRuleVersion", fields: [ruleVersionId], references: [id], onDelete: SetNull)
  items                    OrderItem[]
  usedCoupon               UserCoupon?              @relation("OrderUsedCoupon")
  afterSale                AfterSale?

  @@index([userId, status, createdAt])
  @@index([inviterUserId, createdAt])
  @@index([levelTwoInviterUserId, createdAt])
  @@index([ruleVersionId, createdAt])
}

model OrderItem {
  id             String      @id @default(cuid())
  orderId        String
  productId      String?
  skuId          String?
  title          String
  specText       String?
  price          Decimal     @db.Decimal(10, 2)
  quantity       Int         @default(1)
  subtotalAmount Decimal     @db.Decimal(10, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku            ProductSku? @relation(fields: [skuId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model CouponTemplate {
  id          String               @id @default(cuid())
  code        String               @unique
  title       String
  amount      Decimal              @db.Decimal(10, 2)
  threshold   Decimal              @db.Decimal(10, 2)
  badge       String?
  description String?
  issueType   CouponIssueType      @default(center_claim)
  validDays   Int                  @default(7)
  status      CouponTemplateStatus @default(enabled)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  coupons     UserCoupon[]

  @@index([status, issueType, createdAt])
}

model UserCoupon {
  id             String               @id @default(cuid())
  userId         String
  templateId     String
  status         UserCouponStatus     @default(available)
  sourceType     UserCouponSourceType @default(center_claim)
  sourceText     String?
  claimedAt      DateTime             @default(now())
  expiresAt      DateTime
  usedAt         DateTime?
  usedOrderId    String?              @unique
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  template       CouponTemplate       @relation(fields: [templateId], references: [id], onDelete: Restrict)
  usedOrder      Order?               @relation("OrderUsedCoupon", fields: [usedOrderId], references: [id], onDelete: SetNull)
  selectedByCart Cart[]               @relation("SelectedCartCoupon")

  @@index([userId, status, expiresAt])
  @@index([userId, templateId, sourceType])
  @@index([templateId, status])
}

model AfterSale {
  id           String          @id @default(cuid())
  orderId      String          @unique
  userId       String
  reason       String
  description  String?         @db.LongText
  status       AfterSaleStatus @default(processing)
  reviewRemark String?         @db.LongText
  reviewedAt   DateTime?
  reviewedBy   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ReferralBinding {
  id            String   @id @default(cuid())
  inviterUserId String
  inviteeUserId String   @unique
  sourceScene   String   @default("share")
  boundAt       DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  inviter       User     @relation("UserSentReferrals", fields: [inviterUserId], references: [id], onDelete: Cascade)
  invitee       User     @relation("UserReceivedReferral", fields: [inviteeUserId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@index([inviterUserId, boundAt])
}

model DistributorProfile {
  id                     String              @id @default(cuid())
  userId                 String              @unique
  level                  String              @default("普通分销员")
  status                 DistributorStatus   @default(active)
  totalCommission        Decimal             @default(0.00) @db.Decimal(10, 2)
  pendingCommission      Decimal             @default(0.00) @db.Decimal(10, 2)
  settledCommission      Decimal             @default(0.00) @db.Decimal(10, 2)
  withdrawableCommission Decimal             @default(0.00) @db.Decimal(10, 2)
  withdrawingCommission  Decimal             @default(0.00) @db.Decimal(10, 2)
  withdrawnCommission    Decimal             @default(0.00) @db.Decimal(10, 2)
  teamCount              Int                 @default(0)
  todayInviteCount       Int                 @default(0)
  joinedAt               DateTime            @default(now())
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamMembers            TeamMember[]
  commissionRecords      CommissionRecord[]
  withdrawalRequests     WithdrawalRequest[]

  @@index([status, createdAt])
}

model TeamMember {
  id                String             @id @default(cuid())
  distributorId     String
  nickname          String
  avatarLabel       String
  joinedAt          DateTime
  contributedAmount Decimal            @default(0.00) @db.Decimal(10, 2)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  distributor       DistributorProfile @relation(fields: [distributorId], references: [id], onDelete: Cascade)

  @@index([distributorId, joinedAt])
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String?
  linkType  String   @default("none")
  linkValue String?
  sortOrder Int      @default(0)
  status    String   @default("enabled")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, sortOrder])
}

model PageSection {
  id         String   @id @default(cuid())
  sectionKey String   @unique
  sortOrder  Int      @default(0)
  visible    Boolean  @default(true)
  config     String?  @db.MediumText
  updatedAt  DateTime @updatedAt
}

model StoreTheme {
  id         String   @id @default(cuid())
  themeKey   String   @unique
  themeValue String
  updatedAt  DateTime @updatedAt
}

model PaymentOrder {
  id                 String    @id @default(cuid())
  orderId            String    @unique
  orderNo            String    @unique
  userId             String
  provider           String    @default("mock")
  status             String    @default("prepared")
  amount             Decimal   @db.Decimal(10, 2)
  currency           String    @default("CNY")
  paymentNo          String?
  mockToken          String?
  preparedAt         DateTime?
  paidAt             DateTime?
  expiresAt          DateTime?
  requestPayloadJson String?   @db.MediumText
  resultPayloadJson  String?   @db.MediumText
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId, status, createdAt])
  @@index([orderNo, createdAt])
}

model CommissionRecord {
  id              String                   @id @default(cuid())
  distributorId   String
  ruleVersionId   String?
  title           String
  fromUser        String
  orderNo         String
  amount          Decimal                  @db.Decimal(10, 2)
  levelText       String
  status          CommissionStatus         @default(pending)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  distributor     DistributorProfile       @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  ruleVersion     DistributionRuleVersion? @relation("CommissionRuleVersion", fields: [ruleVersionId], references: [id], onDelete: SetNull)
  withdrawalItems WithdrawalRequestItem[]

  @@index([distributorId, status, createdAt])
  @@index([ruleVersionId, createdAt])
}

model WithdrawalRequest {
  id            String                  @id @default(cuid())
  requestNo     String                  @unique
  distributorId String
  status        WithdrawalStatus        @default(submitted)
  amount        Decimal                 @db.Decimal(10, 2)
  serviceFee    Decimal                 @default(0.00) @db.Decimal(10, 2)
  netAmount     Decimal                 @db.Decimal(10, 2)
  channel       String                  @default("manual_bank")
  accountName   String?
  accountNoMask String?
  remark        String?                 @db.LongText
  reviewRemark  String?                 @db.LongText
  reviewedBy    String?
  reviewedAt    DateTime?
  paidAt        DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  distributor   DistributorProfile      @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  items         WithdrawalRequestItem[]
  payouts       WithdrawalPayout[]

  @@index([distributorId, status, createdAt])
}

model WithdrawalRequestItem {
  id                  String            @id @default(cuid())
  withdrawalRequestId String
  commissionRecordId  String            @unique
  amount              Decimal           @db.Decimal(10, 2)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  withdrawalRequest   WithdrawalRequest @relation(fields: [withdrawalRequestId], references: [id], onDelete: Cascade)
  commissionRecord    CommissionRecord  @relation(fields: [commissionRecordId], references: [id], onDelete: Restrict)

  @@index([withdrawalRequestId, createdAt])
}

model WithdrawalPayout {
  id                  String            @id @default(cuid())
  withdrawalRequestId String
  channel             String            @default("manual_bank")
  channelBillNo       String?
  status              String            @default("paid")
  remark              String?           @db.LongText
  paidBy              String?
  paidAt              DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  withdrawalRequest   WithdrawalRequest @relation(fields: [withdrawalRequestId], references: [id], onDelete: Cascade)

  @@index([withdrawalRequestId, createdAt])
  @@index([channelBillNo])
}

model DistributionRuleVersion {
  id                  String                        @id @default(cuid())
  versionNo           String                        @unique
  enabled             Boolean                       @default(true)
  levelOneRate        Decimal                       @default(8.00) @db.Decimal(5, 2)
  levelTwoRate        Decimal                       @default(3.00) @db.Decimal(5, 2)
  bindDays            Int                           @default(15)
  minWithdrawalAmount Decimal                       @default(0.00) @db.Decimal(10, 2)
  serviceFeeRate      Decimal                       @default(0.0000) @db.Decimal(6, 4)
  serviceFeeFixed     Decimal                       @default(0.00) @db.Decimal(10, 2)
  ruleDesc            String?                       @db.LongText
  status              DistributionRuleVersionStatus @default(draft)
  effectiveAt         DateTime?
  publishedAt         DateTime?
  publishedBy         String?
  createdBy           String?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  orders              Order[]                       @relation("OrderRuleVersion")
  commissionRecords   CommissionRecord[]            @relation("CommissionRuleVersion")
  changeLogs          DistributionRuleChangeLog[]

  @@index([status, createdAt])
}

model DistributionRuleChangeLog {
  id            String                   @id @default(cuid())
  ruleVersionId String?
  action        String
  summary       String?
  payloadJson   String?                  @db.MediumText
  actorId       String?
  actorName     String?
  createdAt     DateTime                 @default(now())
  ruleVersion   DistributionRuleVersion? @relation(fields: [ruleVersionId], references: [id], onDelete: SetNull)

  @@index([ruleVersionId, createdAt])
  @@index([action, createdAt])
}
