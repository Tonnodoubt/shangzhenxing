# 本地 Docker MySQL 默认可直接配合 server/compose.local-mysql.yml 使用
DATABASE_URL="mysql://root:password@127.0.0.1:3306/wechat_mini_shop"
PORT=3000
# 默认仍保持 memory，做真库回归时再临时切到 prisma
STOREFRONT_DATA_SOURCE=memory
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
# 本地开发默认允许 mock 登录；如需模拟正式环境，可改成 false。
ALLOW_MOCK_WECHAT_LOGIN=true
