# 本地 Docker MySQL 默认可直接配合 server/compose.local-mysql.yml 使用。
DATABASE_URL="mysql://root:password@127.0.0.1:3306/wechat_mini_shop"
PORT=3000
NODE_ENV=development

# 默认仍保持 memory，做真库回归时再临时切到 prisma。
STOREFRONT_DATA_SOURCE=memory

# 本地开发默认允许 mock 登录；如需模拟正式环境，可改成 false。
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
ALLOW_MOCK_WECHAT_LOGIN=true

# 支付通道：商户未就绪时保持 mock；后续可切 wechat_jsapi。
PAYMENT_PROVIDER=mock
WECHAT_PAY_MCH_ID=""
WECHAT_PAY_SERIAL_NO=""
WECHAT_PAY_PRIVATE_KEY=""
WECHAT_PAY_NOTIFY_URL=""
WECHAT_PAY_API_V3_KEY=""
WECHAT_PAY_PLATFORM_PUBLIC_KEY=""
WECHAT_PAY_PLATFORM_SERIAL=""

# 前台关键接口限流（单位毫秒/次数）。如不配置，代码使用内置默认值。
STOREFRONT_RATE_LIMIT_WINDOW_MS=600000
STOREFRONT_RATE_LIMIT_AUTH_SESSION_MAX=20
STOREFRONT_RATE_LIMIT_AUTH_AUTHORIZE_MAX=30
STOREFRONT_RATE_LIMIT_ORDER_SUBMIT_MAX=40
STOREFRONT_RATE_LIMIT_PAYMENT_PREPARE_MAX=80
STOREFRONT_RATE_LIMIT_PAYMENT_MOCK_CONFIRM_MAX=120
STOREFRONT_RATE_LIMIT_AFTERSALE_SUBMIT_MAX=30

# 如需按接口单独设置窗口，可覆盖以下值；不配则继承 STOREFRONT_RATE_LIMIT_WINDOW_MS。
# STOREFRONT_RATE_LIMIT_AUTH_SESSION_WINDOW_MS=600000
# STOREFRONT_RATE_LIMIT_AUTH_AUTHORIZE_WINDOW_MS=600000
# STOREFRONT_RATE_LIMIT_ORDER_SUBMIT_WINDOW_MS=600000
# STOREFRONT_RATE_LIMIT_PAYMENT_PREPARE_WINDOW_MS=600000
# STOREFRONT_RATE_LIMIT_PAYMENT_MOCK_CONFIRM_WINDOW_MS=600000
# STOREFRONT_RATE_LIMIT_AFTERSALE_SUBMIT_WINDOW_MS=600000

# 本地可不填 ADMIN_USERS，代码会回退到演示账号。
# ADMIN_USERS='[{"id":"admin-1","username":"admin","realName":"商城管理员","mobile":"13800000001","passwordHash":"REPLACE_WITH_BCRYPT_HASH","roleCodes":["super_admin"]}]'

# 只在浏览器跨域访问接口时需要配置。
CORS_ORIGINS="http://127.0.0.1:3000,http://localhost:3000"
ADMIN_SESSION_TTL_MS=28800000
DATABASE_TCP_PROBE_TIMEOUT_MS=2000

# 如需上传到 COS，四个变量必须同时配置；本地可留空走 /uploads。
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET=""
COS_REGION=""
